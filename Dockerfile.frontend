FROM python:3.9-slim

WORKDIR /app

# Copiar requirements
COPY requirements.txt .

# Instalar dependencias con timeout más largo
RUN pip install --no-cache-dir --default-timeout=1000 -r requirements.txt

# Copiar código
COPY . .

# Copiar script de startup
COPY start_frontend.sh .
RUN chmod +x start_frontend.sh

# Exponer puerto 8050
EXPOSE 8050

# Ejecutar frontend
CMD ["./start_frontend.sh"]
