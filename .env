# OPCIÓN 3: Vertex AI con Service Account (para producción/CI)
# Descomenta la siguiente línea además del GCP_PROJECT_ID:
# GOOGLE_APPLICATION_CREDENTIALS=C:/ruta/completa/agente-politico-key.json

# ========================================
# MODO DE ALMACENAMIENTO
# ========================================

# ENV: Define si usar SQLAlchemy (cloud) o Pandas DataFrames (local)
# - "local": Pandas DataFrames guardados en CSV/Pickle (RÁPIDO, desarrollo)
# - "cloud": SQLAlchemy con SQLite/PostgreSQL (producción)
ENV=local

