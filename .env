GEMINI_MODEL=gemini-2.5-flash-lite

# OPCIÓN 2: Google AI Studio - Free Tier
# Obtén tu API key en: https://aistudio.google.com/app/apikey
# Descomenta la siguiente línea y comenta GCP_PROJECT_ID arriba:
